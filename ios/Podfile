# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Required by @react-native-firebase: FirebaseCoreInternal (Swift) depends on
# GoogleUtilities and needs module maps to import it as a static library.
use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'MOptic' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Create stub RuntimeAdapter.h -- new hermes-engine removed this header from
    # public API, but react-native-reanimated (with HERMES_ENABLE_DEBUGGER=1)
    # still pulls it in transitively through Registration.h.
    # Write to destroot (the actual file); pod install creates a symlink from
    # Headers/Public pointing here, so both paths resolve correctly.
    hermes_inspector_dir = File.join(
      installer.sandbox.root,
      "hermes-engine/destroot/include/hermes/inspector"
    )
    FileUtils.mkdir_p(hermes_inspector_dir)
    # RuntimeAdapter is used unqualified inside namespace
    # facebook::hermes::inspector_modern::chrome, so it must live in
    # inspector_modern (parent ns lookup finds it there).
    stub_content = [
      "// Stub: hermes removed this from public headers; kept for source compat.",
      "#pragma once",
      "#include <hermes/hermes.h>",
      "namespace facebook { namespace hermes { namespace inspector_modern {",
      "class RuntimeAdapter {",
      "public:",
      "  virtual ~RuntimeAdapter() = default;",
      "  virtual ::facebook::hermes::HermesRuntime &getRuntime() = 0;",
      "  virtual void tickleJs() = 0;",
      "};",
      "} } } // namespace facebook::hermes::inspector_modern",
    ].join("\n") + "\n"
    stub_path = File.join(hermes_inspector_dir, "RuntimeAdapter.h")
    # File may be read-only from a previous run; make it writable first.
    File.chmod(0644, stub_path) if File.exist?(stub_path)
    File.write(stub_path, stub_content)

    # Patch REASwizzledUIManager.mm: RCTRootView.intrinsicContentSize setter was
    # removed under RCT_REMOVE_LEGACY_ARCH (new arch). Guard the assignment so
    # the file still compiles with React Native 0.84+ new arch enabled.
    rea_swizzled_path = File.join(
      installer.sandbox.root,
      "../../node_modules/react-native-reanimated/apple/reanimated/apple/LayoutReanimation/REASwizzledUIManager.mm"
    )
    if File.exist?(rea_swizzled_path)
      content = File.read(rea_swizzled_path)
      old_line = "          rootView.intrinsicContentSize = contentSize;"
      new_line = "#ifndef RCT_REMOVE_LEGACY_ARCH\n          rootView.intrinsicContentSize = contentSize;\n#endif"
      if content.include?(old_line) && !content.include?("#ifndef RCT_REMOVE_LEGACY_ARCH")
        File.chmod(0644, rea_swizzled_path)
        File.write(rea_swizzled_path, content.sub(old_line, new_line))
      end
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['SWIFT_VERSION'] = '5.0'
        # Disable treat-warnings-as-errors globally for pods (Xcode 26 beta compatibility)
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        # Suppress specific warnings at compiler level as well
        existing_flags = config.build_settings['OTHER_CFLAGS'] || '$(inherited)'
        config.build_settings['OTHER_CFLAGS'] = "#{existing_flags} -Wno-error=non-modular-include-in-framework-module -Wno-return-type"
        existing_cxx_flags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{existing_cxx_flags} -Wno-error=non-modular-include-in-framework-module -Wno-return-type"
      end
    end
  end
end
